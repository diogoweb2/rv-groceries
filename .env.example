# Firebase project config — get these from Firebase Console → Project Settings → Your apps
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# Shared app credentials (stored in password manager, same for both users)
# These are the Firebase Auth email+password — NOT the app PIN
VITE_APP_EMAIL=rv-app@yourdomain.com
VITE_APP_PASSWORD=your-firebase-auth-password

# The 4-6 digit PIN shown on the login screen
VITE_APP_PIN=your-app-pin

# Firebase Cloud Messaging VAPID key
# Firebase Console → Project Settings → Cloud Messaging → Web Push certificates → Key pair
VITE_FIREBASE_VAPID_KEY=your-vapid-key
